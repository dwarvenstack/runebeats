# ─────────────────────────────────────────────────────────────
#  RuneBeats — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# Discord Bot Token (from discord.dev > Your Application > Bot)
DISCORD_TOKEN=your_bot_token_here

# Discord Application ID (from discord.dev > Your Application > General Information)
CLIENT_ID=your_application_id_here

# (Optional) Restrict slash command registration to a single test server.
# Leave blank to register commands globally (takes ~1 hour to propagate).
GUILD_ID=

# SoundCloud Client ID (register a free app at developers.soundcloud.com)
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Spotify API credentials (register a free app at developer.spotify.com) (Must Have Spotify Premium Account)

#SPOTIFY_CLIENT_ID=your_spotify_client_id_here
#SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here