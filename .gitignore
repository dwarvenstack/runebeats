# ===========================
# HARMONIA — Discord Music Bot
# .gitignore
# ===========================

# --- Environment & Secrets ---
# NEVER commit tokens or API keys
.env
.env.local
.env.development
.env.production
*.env

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# --- Logs ---
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# --- Runtime & Cache ---
.npm/
.node_repl_history
.cache/
dist/
build/

# --- OS Files ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# --- Editor & IDE ---
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Vim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]

# Emacs
*~
\#*\#
.\#*

# --- Testing ---
coverage/
.nyc_output/
test-results/

# --- Temporary Files ---
tmp/
temp/
*.tmp
*.bak
*.backup

# --- Audio / Media (downloaded files) ---
# Don't accidentally commit downloaded audio
*.mp3
*.mp4
*.wav
*.ogg
*.flac
*.aac
*.m4a
*.webm
downloads/
media/

# --- PM2 (process manager) ---
.pm2/
ecosystem.config.js.bak

# --- Docker (if added later) ---
.dockerignore
docker-compose.override.yml


node_modules/
.env
*.log
npm-debug.log*
.DS_Store
